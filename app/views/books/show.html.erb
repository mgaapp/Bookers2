<div>

  <%= image_tag @books.get_image %>

  <p>ショップ名：<%= @books.shop_name %></p>

  <p>説明：<%= @books.caption %></p>

  <p>投稿ユーザー画像：<%= image_tag @books.user.get_profile_image(100,100) %></p>
  <p>ユーザーネーム：<%= @books.user.name %></p>

  <p>投稿日時：<%= @books.created_at.strftime('%Y/%m/%d') %></p>

  <% if @books.user == current_user %>

    <%= link_to "削除", post_image_path(@books), method: :delete %>

  <% end %>

</div>