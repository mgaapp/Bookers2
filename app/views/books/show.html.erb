<div class="container">
  <div class="row">
    <div class="col-md-3">
      <%= render 'list', user: @user %>
    </div>

    <div class="col-md-8 offset-md-1">
      <h2>Book detail</h2>
      <hr style="border-top: 1px solid #ccc; margin-bottom: 1rem;">

      <table class="table">
  <tbody>
    <tr>
      <td>
        <div class="d-flex align-items-start gap-4 flex-wrap">
          <br>
        </div> <!-- d-flexのdiv閉じる -->
      </td>
      <td>
        <div>
          <%= link_to user_path(@book.user) do %>
            <%= image_tag @book.user.get_profile_image(100, 100), alt: @book.user.name %><br>
            <%= @book.user.name %>
          <% end %>
        </div>
      </td>
      <td>
  <div class="d-flex align-items-start gap-3">
    <p><%= @book.title %></p>
    <p><%= @book.body %></p>
  </div>
</td>
      <td>
        <% if @book.user == Current.user %>
          <div class="mt-2">
            <%= link_to "Edit", edit_book_path(@book), class: "btn btn-primary btn-sm me-2" %>
            <%= link_to "Destroy", book_path(@book), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, class: "btn btn-danger btn-sm" %>
          </div>
        <% end %>
      </td>
    </tr>
  </tbody>
</table>