<h1>投稿一覧</h1>

<%= @books.each do |book| %>
<p>投稿ユーザー画像：<%= image_tag book.user.get_profile_image(100,100) %></p>


  <p>タイトル</p>
  <span><%= book.title %></span>
  
<% end %>
<div>

</div>

<!-- ユーザーの投稿一覧 -->
<% @books.each do |post_image| %>
<p>投稿ユーザー画像：<%= image_tag post_image.user.get_profile_image(100,100) %></p>



<div>
 <p>タイトル：<%= post_image.title %></p>
  <p>本文：<%= post_image.body %></p> 
</div>
<% end %>

<h1>New book</h1>
<!-- form_with部分 -->
<%= form_with model: @book do |f| %>
  <h4>Title</h4>
  <%= f.text_field :title %>
	
  <h4>Opinion</h4>
  <%= f.text_area :body %>
	
  
  <%= f.submit "Create Book" %>

<% end %>