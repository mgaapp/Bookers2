<% if @book.errors.any? %>
  <%= @book.errors.count %>件のエラーが発生しました
  <ul>
    <% @book.errors.full_messages.each do |message| %>
      <li><%= message %></li>
    <% end %>
  </ul>
<% end %>



<h1>投稿一覧</h1>
<% @books.each do |book| %>
  <div>
  <p>投稿ユーザー画像：<%= image_tag book.user.get_profile_image(100,100) %></p>
  <p>name ユーザーネーム：<%= book.user.name %></p>
  <p>Title：<%= book.title %></p>
  <p>Opinion：<%= book.body %></p> 
  <% if book.user == Current.user %>
  <%= link_to "Edit", edit_book_path(book) %> |
  <%= link_to "Destroy", book_path(book), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" } %>
  <% end %>
  </div>
<% end %>
<h1>New book</h1>
<!-- form_with部分 -->
<%= form_with model: @book do |f| %>
  <h4>Title</h4>
  <%= f.text_field :title %>
	
  <h4>Opinion</h4>
  <%= f.text_area :body %>
	
  
  <%= f.submit "Create Book" %>

<% end %>

