<header>
  <ul>
 <li><%= link_to 'Home', root_path %></li>
  <li><%= link_to 'Users', user_path%></li>
<li><%= link_to 'Books', books_path(@book) %></li>
<li><%= link_to "Log out", session_path, data: { turbo_method: :delete } %></li>
 </ul>
 </header>




<h2>User info</h2>


<!-- ユーザーの詳細 -->
<div>
  <h3>name:<%= @user.name %></h3>
  <%= image_tag @user.get_profile_image(100,100) %>
  <h5>introduction:<%= @user.introduction %></h5>
</div>
<% if @user == @user %>
    <p><%= link_to "プロフィール編集", edit_user_path(@user) %></p>
  <% end %>

<!-- ユーザーの投稿一覧 -->
<% @books.each do |book| %>
  <div>
  <p>投稿ユーザー画像：<%= image_tag book.user.get_profile_image(100,100) %></p>
  <p>name ユーザーネーム：<%= book.user.name %></p>
  <p>Title：<%= book.title %></p>
  <p>Opinion：<%= book.body %></p> 
   <% if book.user == current_user %>
    <%= link_to "Edit", edit_book_path(post_image) %> |
    <%= link_to "Destroy", book_path(book), method: :delete, data: { confirm: '本当に削除しますか？' } %>
  <% end %>
  </div>
<% end %>


<h1>New book</h1>
<!-- form_with部分 -->
<%= form_with model: @book do |f| %>
  <h4>Title</h4>
  <%= f.text_field :title %>
	
  <h4>Opinion</h4>
  <%= f.text_area :body %>
	
  
  <%= f.submit "Create Book" %>

<% end %>