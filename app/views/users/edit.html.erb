<h1>User info</h1>



<%= form_with model: @user do |f| %>
  <h4>Name</h4>
  <%= f.text_field :name %>
<h6>Image</h6>
  <%= f.file_field :profile_image, placeholder: "ファイルを選択", accept: "image/*" %> 

  <h5>Introduction </h5>
  <%= f.text_area :introduction %>
	
  <p>
  <%= f.submit 'Update User' %>
  </p>

  
<% end %>