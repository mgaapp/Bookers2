<main>
  <p></p>
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-sm-12 col-md-8 col-lg-5 px-5 px-sm-0">
        <h2>Log in</h2>

        <div>
          <%= flash[:notice] %>
        </div>

        <%= form_with url: session_path, local: true, class: "mt-5" do |form| %>
          <div class="mb-3">
            <%= form.label :name, "Name" %>
            <%= form.text_field :name, required: true, autofocus: true, autocomplete: "username", placeholder: "Enter your name", value: params[:name], class: "form-control" %>
          </div>
          <div class="mb-3">
            <%= form.label :password, "Password" %>
            <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "Enter your password", maxlength: 72, class: "form-control" %>
          </div>
          <div class="form-check mb-3">
            <input name="user[remember_me]" type="hidden" value="0" autocomplete="off">
            <%= form.check_box :remember_me, class: "form-check-input", id: "user_remember_me" %>
            <%= form.label :remember_me, "Remember me", class: "form-check-label", for: "user_remember_me" %>
          </div>
          <%= form.submit "Log in", class: "btn btn-primary" %>
        <% end %>

        <div class="mt-3">
          <%= link_to "Sign up", new_user_path %>
        </div>
        <div>
          <%= link_to "Forgot your password?", "/password_resets/new" %>
        </div>

      </div>
    </div>
  </div>
</main>